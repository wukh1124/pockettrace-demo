# 資料庫（本地開發使用 SQLite 檔案）
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# 認證（Better Auth）
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# 應用基礎網址
BASE_URL=http://localhost:3000

# （選填）內網行動裝置測試用 URL
LOCAL_TEST_URL=http://192.168.x.x:3000

# （選填）允許的跨域來源，部署生產環境時設定（逗號分隔）
# 例如：https://pockettrace.com,https://www.pockettrace.com
ALLOWED_ORIGINS=

# ==================== Demo 模式設定 ====================
# 啟用 Demo 模式：使用者無需登入（自動使用 demo 帳號），AI 功能返回預設資料
# 統計數據顯示固定示範數值，頁面底部會顯示 Demo 環境標注
IS_DEMO_MODE=true

# Demo 使用者設定（選填，預設為 demo@example.com / demo123456）
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=demo123456

# ==================== AI Provider ==================== 

# 切換用 (支援 nvidia | openrouter | demo)
# 若 IS_DEMO_MODE=true，建議設為 demo 以完全避免呼叫真實 AI API
NUXT_AI_PROVIDER=demo

# 通用設定
NUXT_AI_TIMEOUT=30000
NUXT_AI_DEFAULT_TEMPERATURE=0.7

# NVIDIA NIM
NUXT_AI_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NUXT_AI_NVIDIA_API_KEY=nvapi-your-api-key
NUXT_AI_NVIDIA_MODEL=meta/llama-3.2-11b-vision-instruct

# OpenRouter
NUXT_AI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NUXT_AI_OPENROUTER_API_KEY=sk-or-your-api-key
NUXT_AI_OPENROUTER_MODEL=minimax/minimax-m2.5:free

# 公開資訊 (用於 OpenRouter App Attribution)
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SITE_NAME=Nuxt_AI_Core